{
  "version": 1,
  "compiledAt": "2026-04-02T09:06:00.000Z",
  "testHash": "691e7a81aaf0773672ba5293d3c90cf1b064dc539f090a8b3f2aa618520db2ac",
  "title": "Login API Returns Valid JWT",
  "actions": [
    {
      "step": 1,
      "instruction": "Send POST request to /api/auth/login with email and password from prerequisites",
      "action": "api_request",
      "method": "POST",
      "url": "/api/auth/login",
      "body": {
        "email": "admin@example.com",
        "password": "admin123"
      },
      "description": "Login with admin credentials"
    },
    {
      "step": 2,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200,
      "description": "Verify login returns 200"
    },
    {
      "step": 3,
      "instruction": "Assert response body contains accessToken field",
      "action": "assert_body",
      "path": "data.accessToken",
      "exists": true,
      "description": "Verify JWT accessToken is in response"
    },
    {
      "step": 4,
      "instruction": "Store the accessToken for later use",
      "action": "store_value",
      "from": "response.data.accessToken",
      "as": "authToken",
      "description": "Store JWT token for next request"
    },
    {
      "step": 5,
      "instruction": "Set Authorization header with stored token",
      "action": "set_header",
      "name": "Authorization",
      "value": "Bearer {{authToken}}",
      "description": "Set auth header for profile request"
    },
    {
      "step": 6,
      "instruction": "Send GET request to /api/auth/profile",
      "action": "api_request",
      "method": "GET",
      "url": "/api/auth/profile",
      "description": "Fetch user profile with stored token"
    },
    {
      "step": 7,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200,
      "description": "Verify profile returns 200"
    },
    {
      "step": 8,
      "instruction": "Assert response body field data.user.email equals admin@example.com",
      "action": "assert_body",
      "path": "data.user.email",
      "equals": "admin@example.com",
      "description": "Verify email matches login credential"
    }
  ]
}
