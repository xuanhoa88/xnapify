{
  "version": 1,
  "compiledAt": "2026-04-08T03:22:56.832Z",
  "testHash": "080541ccfe3cad6d83ae57b41c89e3991fa08314c0db0b8a378b248d24e811ac",
  "title": "Login API Returns Valid JWT",
  "actions": [
    {
      "step": 1,
      "instruction": "Send POST request to /api/auth/login with email and password from prerequisites",
      "action": "api_request",
      "method": "POST",
      "url": "/api/auth/login",
      "body": {
        "email": "{{email}}",
        "password": "{{password}}"
      },
      "description": "Login with credentials from prerequisites"
    },
    {
      "step": 2,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200,
      "description": "Verify response status is 200"
    },
    {
      "step": 3,
      "instruction": "Assert response body contains \"accessToken\" field",
      "action": "assert_body",
      "path": "accessToken",
      "exists": true,
      "description": "Verify token field exists in response body"
    },
    {
      "step": 4,
      "instruction": "Store the token from response body field \"accessToken\" as \"authToken\"",
      "action": "store_value",
      "from": "accessToken",
      "as": "authToken",
      "description": "Store the JWT token for later use"
    },
    {
      "step": 5,
      "instruction": "Set Authorization header to \"Bearer {{authToken}}\"",
      "action": "set_header",
      "name": "Authorization",
      "value": "Bearer {{authToken}}",
      "description": "Set a persistent request header using a stored value"
    },
    {
      "step": 6,
      "instruction": "Send GET request to /api/auth/profile",
      "action": "api_request",
      "method": "GET",
      "url": "/api/auth/profile",
      "description": "Fetch current user profile"
    },
    {
      "step": 7,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200,
      "description": "Verify response status is 200"
    },
    {
      "step": 8,
      "instruction": "Assert response body field \"user.email\" equals \"admin@example.com\"",
      "action": "assert_body",
      "path": "user.email",
      "equals": "admin@example.com",
      "description": "Verify user email matches login credential"
    }
  ]
}