{
  "version": 1,
  "compiledAt": "2026-04-07T13:50:03.560Z",
  "testHash": "b25471ac8e3b832c63b8c33f5b15508f803a7ecb2b4cfa80cce846b8a4bba830",
  "title": "Login API Returns Valid JWT",
  "actions": [
    {
      "step": 1,
      "instruction": "Send POST request to /api/auth/login with email and password from prerequisites",
      "action": "api_request",
      "method": "POST",
      "url": "/api/auth/login",
      "body": {
        "email": "{{email}}",
        "password": "{{password}}"
      },
      "description": "Login with email and password from prerequisites"
    },
    {
      "step": 2,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200
    },
    {
      "step": 3,
      "instruction": "Assert response body contains \"token\" field",
      "action": "assert_body",
      "path": "token",
      "exists": true
    },
    {
      "step": 4,
      "instruction": "Use the token to send GET request to /api/auth/profile",
      "action": "api_request",
      "method": "GET",
      "url": "/api/auth/profile",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      },
      "description": "Send GET request to /api/auth/profile with JWT token"
    },
    {
      "step": 5,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200
    },
    {
      "step": 6,
      "instruction": "Assert response body field \"user.email\" equals \"admin@example.com\"",
      "action": "assert_body",
      "path": "user.email",
      "equals": "admin@example.com"
    }
  ]
}