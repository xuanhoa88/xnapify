{
  "version": 1,
  "compiledAt": "2026-04-09T02:11:51.127Z",
  "testHash": "6a5222f4ed419ac8b9ac0752e2c39adcf14707eb53ca4f9472127a62835ce8ac",
  "title": "Login API Returns Valid JWT",
  "actions": [
    {
      "step": 1,
      "instruction": "Send POST request to /api/auth/login with email and password from prerequisites",
      "action": "api_request",
      "method": "POST",
      "url": "/api/auth/login",
      "body": {
        "email": "{{email}}",
        "password": "{{password}}"
      },
      "description": "Send POST request to /api/auth/login with email and password from prerequisites"
    },
    {
      "step": 2,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200,
      "description": "Verify response status is 200"
    },
    {
      "step": 3,
      "instruction": "Assert response body contains \"accessToken\" field",
      "action": "assert_body",
      "path": "accessToken",
      "exists": true,
      "description": "Verify token field exists in response body"
    },
    {
      "step": 4,
      "instruction": "Use the token to send GET request to /api/auth/profile",
      "action": "api_request",
      "method": "GET",
      "url": "/api/auth/profile",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      },
      "description": "Use the token to send GET request to /api/auth/profile"
    },
    {
      "step": 5,
      "instruction": "Assert response status is 200",
      "action": "assert_status",
      "expected": 200,
      "description": "Verify response status is 200"
    },
    {
      "step": 6,
      "instruction": "Assert response body field \"user.email\" equals \"admin@example.com\"",
      "action": "assert_body",
      "path": "user.email",
      "equals": "admin@example.com",
      "description": "Verify user email in response body matches the login credential"
    }
  ]
}