{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "*": ["src/*", "*"]
    },
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "target": "esnext"
  },
  "include": ["src/**/*", "shared/**/*", "tools/**/*"],
  "exclude": [
    "node_modules",
    "build",
    "coverage",
    ".cache",
    ".agent",
    ".data",
    "dist"
  ]
}
