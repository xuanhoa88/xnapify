# =============================================================================
# Development Stage — HMR-enabled dev server
# =============================================================================
FROM node:18-alpine

WORKDIR /app

# Install dependencies first (layer cache optimisation)
COPY package*.json ./
COPY tools/npm/ ./tools/npm/
RUN npm run setup

# Source code is bind-mounted at runtime — no COPY needed
# COPY . .  (intentionally omitted)

EXPOSE 1337

CMD ["npm", "run", "dev"]
