# =============================================================================
# Development Stage — HMR-enabled dev server
# =============================================================================
FROM node:18-alpine

# Runtime dependencies for embedded database engines (same as production).
# gcompat: glibc shim for PG/MySQL binaries; curl+xz: MySQL download/extract;
# lz4-libs+zstd-libs+libxml2: PG 18 compression/XML; tzdata: MySQL timezones.
# python3+make+g++: build tools for native modules (sqlite3 requires node-gyp).
RUN apk add --no-cache gcompat libstdc++ icu-libs readline zlib openssl \
    lz4-libs zstd-libs libxml2 \
    curl xz libaio numactl ncurses-libs tzdata \
    python3 py3-setuptools make g++

WORKDIR /app

# Install dependencies first (layer cache optimisation)
COPY package*.json ./
COPY tools/npm/ ./tools/npm/
RUN npm config set fetch-retries 5 \
 && npm config set fetch-retry-mintimeout 20000 \
 && npm config set fetch-retry-maxtimeout 120000 \
 && npm run setup

# Source code is bind-mounted at runtime — no COPY needed
# COPY . .  (intentionally omitted)

EXPOSE 1337

CMD ["npm", "run", "dev"]
